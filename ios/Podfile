# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# RN 0.85 defaults to a PREBUILT (release) React core, which has Metro dev-server
# support AND Fabric debug symbols stripped — that breaks Debug builds for this
# project (link errors: DebugStringConvertible/Sealable; and "No script URL
# provided" at launch). Build React core from source so Debug gets dev-server +
# debug symbols. Override with `RCT_USE_PREBUILT_RNCORE=1` for faster release/CI.
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '0'

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'TraydApp' do
  config = use_native_modules!

  # Firebase's Swift pods (e.g. FirebaseCoreInternal) can only be linked as
  # static libraries if their dependencies expose module maps. Opt the
  # offending Google/Firebase pods into modular headers.
  pod 'GoogleUtilities', :modular_headers => true
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Firebase's Swift pods import GoogleUtilities/FirebaseCore headers that
    # aren't fully modular. With modular headers enabled this trips
    # -Werror=non-modular-include-in-framework-module at compile time, so allow it.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      end
    end
  end
end
